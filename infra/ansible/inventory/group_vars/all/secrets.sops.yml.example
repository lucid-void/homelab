# Plaintext example of secrets.sops.yml (the real file is SOPS-encrypted).
# First-time setup:
#   1. Copy to secrets.sops.yml and fill in values
#   2. Encrypt from repo root:
#        sops --encrypt --in-place infra/ansible/inventory/group_vars/all/secrets.sops.yml
# Subsequent edits:
#   just edit-ansible-secrets

# ---------------------------------------------------------------------------
# Admin / contact
# ---------------------------------------------------------------------------

# Primary admin email — used for Let's Encrypt registration, pgAdmin login, etc.
email: "admin@example.com"

# ACME registration email (separate so it can differ from admin email)
acme_email: "acme@example.com"

# ---------------------------------------------------------------------------
# Cloudflare — one API token per consumer (Zone → DNS → Edit on your domain)
# Create tokens at: https://dash.cloudflare.com/profile/api-tokens
# ---------------------------------------------------------------------------

cloudflare_token_traefik:  "cf-token-traefik-changeme"
cloudflare_token_proxmox:  "cf-token-proxmox-changeme"
cloudflare_token_truenas:  "cf-token-synology-changeme"   # used by Synology DSM ACME

# Zone ID — from the Cloudflare domain overview page (right sidebar)
cloudflare_zone_id: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Proxmox — API token for dynamic inventory and Tofu provisioning
# Create at: Proxmox UI → Datacenter → API Tokens
# ---------------------------------------------------------------------------

proxmox_api_url:   "https://172.16.20.3:8006/api2/json"
proxmox_api_token: "ansible@pve!ansible=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Postgres — one password per database user
# Generate each: openssl rand -base64 24
# ---------------------------------------------------------------------------

postgres_superuser_username: "postgres"
postgres_superuser_password: "changeme"

postgres_password_immich:      "changeme"
postgres_password_paperless:   "changeme"
postgres_password_gitea:       "changeme"
postgres_password_freshrss:    "changeme"
postgres_password_langfuse:    "changeme"
postgres_password_zitadel:     "changeme"
postgres_password_uptime_kuma: "changeme"

# ---------------------------------------------------------------------------
# MariaDB
# Generate: openssl rand -base64 24
# ---------------------------------------------------------------------------

mariadb_root_password: "changeme"

# ---------------------------------------------------------------------------
# pgAdmin
# Generate: openssl rand -base64 24
# ---------------------------------------------------------------------------

pgadmin_default_password: "changeme"

# ---------------------------------------------------------------------------
# Zitadel — identity provider
# masterkey must be exactly 32 bytes.
# Generate: openssl rand -base64 32
# ---------------------------------------------------------------------------

zitadel_masterkey: "changeme-32-bytes-xxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# oauth2-proxy — Traefik forward-auth middleware, OIDC client of Zitadel
# ---------------------------------------------------------------------------

# Client ID and secret from Zitadel (confidential Web Application, PKCE/S256).
# Create at: Zitadel UI → Projects → <project> → Applications → New
# Redirect URI to register: https://auth.<domain>/oauth2/callback
oauth2_proxy_client_id:     "changeme"
oauth2_proxy_client_secret: "changeme"

# 32-byte random key used to sign session cookies.
# Generate: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
oauth2_proxy_cookie_secret: "changeme"

# ---------------------------------------------------------------------------
# Gitea
# Generate all three: openssl rand -hex 32
# ---------------------------------------------------------------------------

gitea_secret_key:     "changeme"
gitea_internal_token: "changeme"
gitea_metrics_token:  "changeme"

# Zitadel OIDC client for Gitea (confidential Web Application).
# Create at: Zitadel UI → Projects → <project> → Applications → New
# Redirect URI to register: https://gitea.<domain>/user/oauth2/Zitadel/callback
gitea_oidc_client_id:     "changeme"
gitea_oidc_client_secret: "changeme"

# ---------------------------------------------------------------------------
# Monitoring — Grafana, Gotify, exporter credentials
# ---------------------------------------------------------------------------

# Grafana admin password (local fallback; OIDC is primary login)
# Generate: openssl rand -base64 24
grafana_admin_password: "changeme"

# Grafana OIDC client for Zitadel (confidential Web Application, PKCE).
# Create at: Zitadel UI → Projects → <project> → Applications → New
# Redirect URI to register: https://grafana.<domain>/login/generic_oauth
grafana_oidc_client_id:     "changeme"
grafana_oidc_client_secret: "changeme"

# Gotify admin password — used on first-run DB init and by Ansible for app bootstrap.
# Generate: openssl rand -base64 24
gotify_admin_password: "changeme"

# Gotify notification tokens for non-Grafana senders.
# Create apps manually in Gotify UI and paste the generated tokens here.
# The Grafana Alerts token is provisioned automatically by the monitoring role.
gotify_token_backup: "changeme"
gotify_drift_token:  "changeme"

# UDM SE read-only account password (for unifi-poller).
# Create a local read-only account in UniFi OS and set its password here.
unifi_poller_password: "changeme"

# ---------------------------------------------------------------------------
# Backup — rclone crypt remote to Filen cloud
# Passwords must be the OBSCURED form produced by rclone:
#   rclone obscure "$(openssl rand -hex 32)"
# ---------------------------------------------------------------------------

rclone_crypt_password: "changeme-obscured"
rclone_crypt_salt:     "changeme-obscured"

# Filen account credentials (used by rclone for the backing remote)
filen_email:    "your@email.com"
filen_password: "changeme"

# ---------------------------------------------------------------------------
# Gitea runner VM — act_runner at 172.16.20.17
# ---------------------------------------------------------------------------

# SSH key pair for runner → VM access (Ansible SSH) and SOPS decryption.
# The SSH ed25519 key doubles as the SOPS age identity (no separate age key needed).
# Generate: ssh-keygen -t ed25519 -C runner@homelab -f /tmp/runner_key
#
# After generating, add the public key as a recipient in .sops.yaml, then
# re-encrypt all secrets: sops updatekeys infra/ansible/inventory/group_vars/all/secrets.sops.yml
#                          sops updatekeys infra/terraform/secrets.sops.tfvars
#                          sops updatekeys infra/packer/credentials.sops.pkr.hcl
runner_ssh_private_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  changeme
  -----END OPENSSH PRIVATE KEY-----
runner_ssh_public_key: "ssh-ed25519 AAAA... runner@homelab"

# Runner registration token — from Gitea admin panel:
#   Site Administration → Runners → Create new runner → Copy token
gitea_runner_token: "changeme"

# ---------------------------------------------------------------------------
# Technitium DNS admin password (Pi-based secondary resolver)
# Generate: openssl rand -base64 24
# ---------------------------------------------------------------------------

technitium_admin_password: "changeme"

# ---------------------------------------------------------------------------
# LLM stack (DGX Spark)
# ---------------------------------------------------------------------------

# HuggingFace token — create at: https://huggingface.co/settings/tokens
huggingface_token: "hf_changeme"

# Generate: openssl rand -base64 32
langfuse_nextauth_secret: "changeme"
