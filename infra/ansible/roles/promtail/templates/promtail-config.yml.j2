server:
  http_listen_port: 9080
  grpc_listen_port: 0
  log_level: warn

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: http://{{ network_prefix }}.16:3100/loki/api/v1/push

scrape_configs:

{% if inventory_hostname in groups.get('proxmox_nodes', []) %}
  # ── System logs — Proxmox (rsyslog-based) ────────────────────────────────
  - job_name: syslog
    static_configs:
      - targets: [localhost]
        labels:
          job: syslog
          host: "{{ inventory_hostname }}"
          __path__: /var/log/syslog

  - job_name: auth
    static_configs:
      - targets: [localhost]
        labels:
          job: syslog
          host: "{{ inventory_hostname }}"
          __path__: /var/log/auth.log

  # ── Proxmox-specific logs ─────────────────────────────────────────────────
  - job_name: pve
    static_configs:
      - targets: [localhost]
        labels:
          job: pve
          host: "{{ inventory_hostname }}"
          __path__: /var/log/pve/*.log

{% else %}
  # ── System journal — Debian VMs (systemd, no rsyslog) ────────────────────
  - job_name: journal
    journal:
      labels:
        job: journal
        host: "{{ inventory_hostname }}"
    relabel_configs:
      - source_labels: [__journal__systemd_unit]
        target_label: unit
      - source_labels: [__journal__comm]
        target_label: command

  # ── Docker container logs ─────────────────────────────────────────────────
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: [__meta_docker_container_name]
        regex: "/(.*)"
        target_label: container_name
      - source_labels: [__meta_docker_container_label_com_docker_swarm_service_name]
        target_label: swarm_service
      - source_labels: [__meta_docker_container_log_stream]
        target_label: stream
      # Set job to swarm service name (or container name) for Grafana logs dashboard
      - source_labels: [container_name]
        target_label: job
      - source_labels: [swarm_service]
        regex: "(.+)"
        target_label: job
    pipeline_stages:
      - json:
          expressions:
            log: log
            stream: stream
      - output:
          source: log

{% endif %}
