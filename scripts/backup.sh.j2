#!/usr/bin/env bash
# Managed by Ansible — do not edit manually
# Deployed to DB VM (.10) at /opt/scripts/backup.sh
# Schedule: 0 3 * * * timeout 4h /opt/scripts/backup.sh >> /var/log/backup.log 2>&1

set -euo pipefail
umask 0027

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
SERVICES_VM="172.16.20.13"
SERVICES_USER="void"

PG_HOST="127.0.0.1"
PG_PORT="5432"
PG_USER="postgres"
export PGPASSFILE="/opt/scripts/.pgpass"

GOTIFY_URL="https://gotify.{{ domain }}/message"
GOTIFY_TOKEN="{{ gotify_token_backup }}"

HEARTBEAT_FILE="/mnt/backups/services/backup-heartbeat"

DATE="$(date +%F)"
TIMESTAMP="$(date -u +%Y%m%dT%H%M%SZ)"
LOG_PREFIX="[backup ${TIMESTAMP}]"

# Databases paired with their media NFS dump dirs (stop service → dump → restart)
declare -A PAIRED_DBS=(
    [immich]="/mnt/media/Photos/dbdump"
    [paperless]="/mnt/media/Paperless/dbdump"
    [gitea]="/mnt/media/Gitea/dbdump"
)

# Databases dumped directly to backups share (no associated service stop needed)
STANDALONE_DBS=(zitadel freshrss)
# tofu_state added once OpenTofu postgres backend is initialised (tofu init run).

# Swarm services to stop/start for consistent dumps
SCALE_DOWN="immich_immich-server=0 immich_immich-machine-learning=0 paperless_paperless=0 gitea_gitea-server=0"
SCALE_UP="immich_immich-server=1 immich_immich-machine-learning=1 paperless_paperless=1 gitea_gitea-server=1"

SERVICES_STOPPED=false

# Set by each step before running; included in failure notification
CURRENT_STEP="init"
ERR_DETAIL=""

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
log() { echo "${LOG_PREFIX} $*"; }

die() {
    ERR_DETAIL="$1"
    log "FATAL: ${ERR_DETAIL}"
    exit 1
}

notify() {
    local title="$1" msg="$2" prio="${3:-5}"
    curl -s --max-time 10 -X POST \
        "${GOTIFY_URL}?token=${GOTIFY_TOKEN}" \
        -F "title=${title}" -F "message=${msg}" -F "priority=${prio}" \
        || log "WARNING: Gotify notification failed (non-fatal)"
}

scale_services() {
    local args="$1"
    local stderr_file
    stderr_file=$(mktemp)
    if ! ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new \
            -o ConnectTimeout=15 \
            -i /root/.ssh/backup_id_ed25519 \
            "${SERVICES_USER}@${SERVICES_VM}" \
            "docker service scale ${args}" 2>"${stderr_file}"; then
        local err; err=$(cat "${stderr_file}")
        rm -f "${stderr_file}"
        ERR_DETAIL="docker service scale ${args} failed: ${err}"
        log "ERROR: ${ERR_DETAIL}"
        return 1
    fi
    rm -f "${stderr_file}"
}

pg_dump_db() {
    local db="$1" dest="$2"
    local stderr_file
    stderr_file=$(mktemp)
    if ! pg_dump -h "${PG_HOST}" -p "${PG_PORT}" -U "${PG_USER}" "${db}" \
            > "${dest}" 2>"${stderr_file}"; then
        local err; err=$(cat "${stderr_file}")
        rm -f "${stderr_file}" "${dest}"
        die "pg_dump failed for '${db}': ${err}"
    fi
    rm -f "${stderr_file}"
}

rclone_sync() {
    local src="$1" dst="$2"
    local stderr_file
    stderr_file=$(mktemp)
    log "Syncing: ${src} → ${dst}"
    if ! /usr/local/bin/rclone sync "${src}" "${dst}" --transfers 16 --progress --log-level INFO \
            2>"${stderr_file}"; then
        local err; err=$(tail -5 "${stderr_file}")
        rm -f "${stderr_file}"
        die "rclone sync '${src}' → '${dst}' failed: ${err}"
    fi
    rm -f "${stderr_file}"
    log "Sync done: ${src}"
}

# ---------------------------------------------------------------------------
# Error trap — restarts services and notifies on any failure
# ---------------------------------------------------------------------------
cleanup_on_error() {
    local rc=$?
    log "FATAL: backup failed in '${CURRENT_STEP}' at line ${BASH_LINENO[0]} (exit ${rc})"
    if "${SERVICES_STOPPED}"; then
        log "Services are still stopped — attempting restart..."
        set +e
        scale_services "${SCALE_UP}"
        local scale_rc=$?
        set -e
        if [ "${scale_rc}" -ne 0 ]; then
            log "ERROR: service restart also failed — manual intervention required on ${SERVICES_VM}"
        else
            log "Services restarted successfully"
        fi
    fi
    local body="Step: ${CURRENT_STEP}"
    if [[ -n "${ERR_DETAIL}" ]]; then
        body="${body}
Error: ${ERR_DETAIL}"
    fi
    body="${body}
Time: ${TIMESTAMP}
See /var/log/backup.log on DB VM"
    notify "Backup FAILED" "${body}" 8
    exit "${rc}"
}
trap cleanup_on_error ERR

# ---------------------------------------------------------------------------
# Step 1: Stop services for consistent database dumps
# ---------------------------------------------------------------------------
log "=== 1. Stop services ==="
CURRENT_STEP="Step 1: stop services"
scale_services "${SCALE_DOWN}"
SERVICES_STOPPED=true
sleep 10

# ---------------------------------------------------------------------------
# Step 2: Dump paired databases into their media NFS dbdump/ subdirs
# ---------------------------------------------------------------------------
log "=== 2. Dump paired databases ==="
for db in "${!PAIRED_DBS[@]}"; do
    CURRENT_STEP="Step 2: pg_dump ${db}"
    dir="${PAIRED_DBS[$db]}"
    mkdir -p "${dir}"
    DUMP_FILE="${dir}/${DATE}-${db}.sql"
    log "Dumping: ${db} → ${DUMP_FILE}"
    pg_dump_db "${db}" "${DUMP_FILE}"
    log "Done: ${db} ($(du -sh "${DUMP_FILE}" | awk '{print $1}'))"
done

# ---------------------------------------------------------------------------
# Step 3: Dump standalone databases to backups/databases NFS share
# ---------------------------------------------------------------------------
log "=== 3. Dump standalone databases ==="
mkdir -p /mnt/backups/databases
for db in "${STANDALONE_DBS[@]}"; do
    CURRENT_STEP="Step 3: pg_dump ${db}"
    DUMP_FILE="/mnt/backups/databases/${DATE}-${db}.sql"
    log "Dumping: ${db} → ${DUMP_FILE}"
    pg_dump_db "${db}" "${DUMP_FILE}"
    log "Done: ${db} ($(du -sh "${DUMP_FILE}" | awk '{print $1}'))"
done

# ---------------------------------------------------------------------------
# Step 4: Restart services — dumps complete, services can resume
# set +e: docker service scale may timeout on large images and return non-zero
# even though services eventually converge. Backup data is already safe here.
# ---------------------------------------------------------------------------
log "=== 4. Restart services ==="
CURRENT_STEP="Step 4: restart services"
set +e
scale_services "${SCALE_UP}"
_scale_rc=$?
set -e
SERVICES_STOPPED=false
if [ "${_scale_rc}" -ne 0 ]; then
    log "WARNING: scale-up returned ${_scale_rc} — services may be slow to converge; continuing"
else
    log "Services restarted successfully"
fi

# ---------------------------------------------------------------------------
# Step 5: Incremental encrypted sync to Filen
# ---------------------------------------------------------------------------
log "=== 5. Sync to Filen (incremental) ==="
CURRENT_STEP="Step 5: rclone sync Photos"
rclone_sync /mnt/media/Photos/      filen-crypt:media/Photos/
CURRENT_STEP="Step 5: rclone sync Paperless"
rclone_sync /mnt/media/Paperless/   filen-crypt:media/Paperless/
CURRENT_STEP="Step 5: rclone sync Gitea"
rclone_sync /mnt/media/Gitea/       filen-crypt:media/Gitea/
CURRENT_STEP="Step 5: rclone sync databases"
rclone_sync /mnt/backups/databases/ filen-crypt:databases/

# ---------------------------------------------------------------------------
# Step 6: Monthly archive — 1st of month, copy databases to permanent archive
# ---------------------------------------------------------------------------
log "=== 6. Monthly archive ==="
if [ "$(date +%d)" = "01" ]; then
    CURRENT_STEP="Step 6: monthly archive"
    log "First of month — archiving to filen-crypt:archive/$(date +%Y-%m)/"
    /usr/local/bin/rclone copy /mnt/backups/databases/ "filen-crypt:archive/$(date +%Y-%m)/" --transfers 16
fi

# ---------------------------------------------------------------------------
# Step 7: Prune local dumps older than 30 days
# ---------------------------------------------------------------------------
log "=== 7. Prune old dumps (>30 days) ==="
CURRENT_STEP="Step 7: prune old dumps"
PRUNED=0
for dir in /mnt/media/Photos/dbdump /mnt/media/Paperless/dbdump /mnt/media/Gitea/dbdump /mnt/backups/databases; do
    while IFS= read -r -d '' f; do
        log "Removing: ${f}"
        rm -f "${f}"
        (( PRUNED++ ))
    done < <(find "${dir}" -name "*.sql" -mtime +30 -print0 2>/dev/null)
done
log "Pruned ${PRUNED} old dump file(s)"

# ---------------------------------------------------------------------------
# Step 8: Write heartbeat (Prometheus alert fires if older than 25 hours)
# ---------------------------------------------------------------------------
log "=== 8. Heartbeat ==="
CURRENT_STEP="Step 8: heartbeat"
mkdir -p "$(dirname "${HEARTBEAT_FILE}")"
date -Iseconds > "${HEARTBEAT_FILE}"

# ---------------------------------------------------------------------------
# Step 9: Success notification
# ---------------------------------------------------------------------------
log "=== 9. Done ==="
notify "Backup OK" "Daily backup completed — offsite sync done (${TIMESTAMP})" 2
log "=== Backup complete: ${TIMESTAMP} ==="
